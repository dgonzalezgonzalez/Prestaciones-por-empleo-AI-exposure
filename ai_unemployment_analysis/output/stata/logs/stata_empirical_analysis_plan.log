. ***** Make Panels
. capture program drop make_panel_files

. program define make_panel_files
  1.     use "$STDTA\stata_master_clean.dta", clear
  2.     keep if lower(dimension) == "total" & lower(category) == "total" & lower(gender) == "total"
  3.     gen str40 sample_name = "total_cno4"
  4.     gen str80 subgroup_name = "all"
  5.     egen unit_id = group(cno4), label
  6.     compress
  7.     save "$STDTA\panel_total_cno4.dta", replace
  8. 
.     use "$STDTA\stata_master_clean.dta", clear
  9.     keep if lower(dimension) == "province"
 10.     gen province = category
 11.     egen province_id = group(province), label
 12.     egen province_ym = group(province ym), label
 13.     egen unit_id = group(province cno4), label
 14.     gen str40 sample_name = "province_cno4"
 15.     gen str80 subgroup_name = "all"
 16.     compress
 17.     save "$STDTA\panel_province_cno4.dta", replace
 18. 
.     use "$STDTA\stata_master_clean.dta", clear
 19.     keep if lower(dimension) == "age"
 20.     gen age_group = category
 21.     egen age_id = group(age_group), label
 22.     egen unit_id = group(age_group cno4), label
 23.     gen str40 sample_name = "age_cno4"
 24.     gen str80 subgroup_name = age_group
 25.     compress
 26.     save "$STDTA\panel_age_cno4.dta", replace
 27. end

