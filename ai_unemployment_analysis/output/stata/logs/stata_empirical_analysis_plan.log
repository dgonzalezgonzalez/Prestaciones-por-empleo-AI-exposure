. ***** Data cleaning
. capture program drop make_clean_master

. program define make_clean_master
  1.     import delimited using "$RAW", clear varnames(1) stringcols(_all) bindquote(strict) encodin
> g("UTF-8")
  2. 
.     rename *, lower
  3.     foreach v in contratos parados personas observed_exposure_rf observed_exposure_cosine_weigh
> t observed_exposure_cosine_weighte observed_exposure_cosine_nearest {
  4.         capture confirm variable `v'
  5.         if !_rc destring `v', replace force
  6.     }
  7. 
.     replace period = trim(period)
  8.     replace cno4 = trim(cno4)
  9.     replace cno4 = substr("0000" + cno4, length("0000" + cno4) - 3, 4) if cno4 != ""
 10.     keep if strlen(cno4) == 4
 11. 
.     gen ym = monthly(period, "YM")
 12.     format ym %tm
 13.     gen year_month = ym
 14. 
.     gen cno2 = substr(cno4, 1, 2)
 15.     gen cno1d = substr(cno4, 1, 1)
 16.     egen cno4_id = group(cno4), label
 17.     egen cno2_id = group(cno2), label
 18.     egen cno1_id = group(cno1d), label
 19.     egen cno2_ym = group(cno2 ym), label
 20.     egen cno1_ym = group(cno1d ym), label
 21. 
.     gen exposure_nearest = observed_exposure_cosine_nearest
 22.     gen exposure_weighted = .
 23.     capture confirm variable observed_exposure_cosine_weight
 24.     if !_rc replace exposure_weighted = observed_exposure_cosine_weight
 25.     capture confirm variable observed_exposure_cosine_weighte
 26.     if !_rc replace exposure_weighted = observed_exposure_cosine_weighte if missing(exposure_we
> ighted)
 27.     gen exposure_rf = observed_exposure_rf
 28.     gen exposure_10pp = exposure_nearest / 0.10
 29. 
.     gen ln_parados = ln(parados) if parados > 0
 30.     gen ln_contratos = ln(contratos) if contratos > 0
 31.     gen parados_contratos = parados / contratos if contratos > 0 & parados < .
 32.         replace parados_contratos=ln(parados_contratos)
 33.     gen event_time_sep2022 = ym - tm(2022m9)
 34.     gen post_sep2022 = ym > tm(2022m9)
 35. 
.     preserve
 36.         keep if lower(dimension) == "total" & lower(category) == "total" & lower(gender) == "to
> tal"
 37.         quietly summarize exposure_nearest, detail
 38.         scalar p75_exposure = r(p75)
 39.     restore
 40. 
.     gen treat_high = exposure_nearest > p75_exposure if exposure_nearest < .
 41.     gen treat_zero = exposure_nearest == 0 if exposure_nearest < .
 42.     gen binary_sample = treat_high == 1 | treat_zero == 1
 43.     gen did_post = treat_high * post_sep2022
 44. 
.     gen byte exposure_group = .
 45.     replace exposure_group = 0 if treat_zero == 1
 46.     replace exposure_group = 1 if exposure_nearest > 0 & exposure_nearest <= p75_exposure
 47.     replace exposure_group = 2 if treat_high == 1
 48.     label define exposure_group 0 "zero" 1 "middle" 2 "high", replace
 49.     label values exposure_group exposure_group
 50. 
.     label variable ln_parados "log(parados)"
 51.     label variable ln_contratos "log(contratos)"
 52.     label variable parados_contratos "parados / contratos"
 53.     label variable did_post "High exposure x post Sep 2022"
 54. 
.     compress
 55.     save "$STDTA\stata_master_clean.dta", replace
 56. 
.     file open meta using "$STTAB\stata_thresholds.txt", write replace
 57.     file write meta "Main high exposure threshold (total panel p75): " %9.6f (p75_exposure) _n
 58.     file write meta "Post definition: ym > September 2022, so post starts October 2022." _n
 59.     file close meta
 60. end

