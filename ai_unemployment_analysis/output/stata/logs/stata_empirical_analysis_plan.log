. ******* STATIC SDID
. capture program drop run_sdid_sc_one

. program define run_sdid_sc_one
  1.     syntax, SAMPLE(string) SUBGROUP(string) TAG(string) OUTCOME(name) ESTIMATOR(string) RESTRIC
> TNAME(string) RESTRICT(string)
  2. 
.     preserve
  3.         keep_balanced_panel, outcome(`outcome') restrict("`restrict'")
  4.         local nobs = r(nobs)
  5.         local units = r(units)
  6.         local periods = r(periods)
  7.         local treated_units = r(treated_units)
  8.         local control_units = r(control_units)
  9. 
.         if `nobs' == 0 | `treated_units' == 0 | `control_units' == 0 | `periods' < 2 {
 10.             post SDIDSC ("`sample'") ("`subgroup'") ("`outcome'") ("`estimator'") ("`restrictna
> me'") ///
>                 (.) (.) (.) (.) (`nobs') (`units') (`periods') (`treated_units') (`control_units')
>  ("not_enough_balanced_data")
 11.             restore
 12.             exit
 13.         }
 14. 
.         local vceopt "vce($SDID_VCE)"
 15.         if "$SDID_VCE" == "placebo" {
 16.             if `control_units' <= `treated_units' {
 17.                 local vceopt "vce(noinference)"
 18.             }
 19.             else {
 20.                 local vceopt "vce(placebo) reps($SDID_REPS) seed($SEED)"
 21.             }
 22.         }
 23.         if "$SDID_VCE" == "bootstrap" {
 24.             local vceopt "vce(bootstrap) reps($SDID_REPS) seed($SEED)"
 25.         }
 26.         if "$SDID_VCE" == "jackknife" {
 27.             local vceopt "vce(jackknife)"
 28.         }
 29. 
.         capture noisily sdid `outcome' unit_id ym did_post, `vceopt' method(`estimator')
 30.         if _rc {
 31.             local rc = _rc
 32.             post SDIDSC ("`sample'") ("`subgroup'") ("`outcome'") ("`estimator'") ("`restrictna
> me'") ///
>                 (.) (.) (.) (.) (`nobs') (`units') (`periods') (`treated_units') (`control_units')
>  ("sdid_rc_`rc'")
 33.             restore
 34.             exit
 35.         }
 36. 
.         matrix b = e(b)
 37.         scalar att = b[1,1]
 38.         scalar se = .
 39.         scalar p = .
 40.         capture matrix V = e(V)
 41.         if !_rc {
 42.             scalar se = sqrt(V[1,1])
 43.             if se < . {
 44.                 scalar p = 2 * (1 - normal(abs(att / se)))
 45.             }
 46.         }
 47.         scalar pct = .
 48.         if inlist("`outcome'", "ln_parados", "ln_contratos") {
 49.             scalar pct = 100 * (exp(att) - 1)
 50.         }
 51.         post SDIDSC ("`sample'") ("`subgroup'") ("`outcome'") ("`estimator'") ("`restrictname'"
> ) ///
>             (att) (se) (p) (pct) (`nobs') (`units') (`periods') (`treated_units') (`control_units'
> ) ("ok")
 52.     restore
 53. end

. 
. 
