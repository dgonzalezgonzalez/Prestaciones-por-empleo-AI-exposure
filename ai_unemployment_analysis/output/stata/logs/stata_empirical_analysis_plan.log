. ***** Sample counts
. capture program drop write_sample_counts

. program define write_sample_counts
  1.     tempfile counts
  2.     postfile COUNTS str40 sample str80 subgroup double rows units periods high_units zero_units
>  cno2_ident_units cno1_ident_units using `counts', replace
  3. 
.     use "$STDTA\panel_total_cno4.dta", clear
  4.     add_restriction_flags
  5.     quietly count
  6.     local rows = r(N)
  7.     quietly distinct unit_id
  8.     local units = r(ndistinct)
  9.     quietly distinct ym
 10.     local periods = r(ndistinct)
 11.     quietly distinct unit_id if treat_high == 1
 12.     local high_units = r(ndistinct)
 13.     quietly distinct unit_id if treat_zero == 1
 14.     local zero_units = r(ndistinct)
 15.     quietly distinct unit_id if cno2_identifying == 1
 16.     local cno2_units = r(ndistinct)
 17.     quietly distinct unit_id if cno1_identifying == 1
 18.     local cno1_units = r(ndistinct)
 19.     post COUNTS ("total_cno4") ("all") (`rows') (`units') (`periods') (`high_units') (`zero_uni
> ts') (`cno2_units') (`cno1_units')
 20. 
.     use "$STDTA\panel_province_cno4.dta", clear
 21.     add_restriction_flags
 22.     quietly count
 23.     local rows = r(N)
 24.     quietly distinct unit_id
 25.     local units = r(ndistinct)
 26.     quietly distinct ym
 27.     local periods = r(ndistinct)
 28.     quietly distinct unit_id if treat_high == 1
 29.     local high_units = r(ndistinct)
 30.     quietly distinct unit_id if treat_zero == 1
 31.     local zero_units = r(ndistinct)
 32.     quietly distinct unit_id if cno2_identifying == 1
 33.     local cno2_units = r(ndistinct)
 34.     quietly distinct unit_id if cno1_identifying == 1
 35.     local cno1_units = r(ndistinct)
 36.     post COUNTS ("province_cno4") ("all") (`rows') (`units') (`periods') (`high_units') (`zero_
> units') (`cno2_units') (`cno1_units')
 37. 
.     use "$STDTA\panel_age_cno4.dta", clear
 38.     levelsof age_group, local(ages)
 39.     foreach a of local ages {
 40.         preserve
 41.             keep if age_group == "`a'"
 42.             add_restriction_flags
 43.             quietly count
 44.             local rows = r(N)
 45.             quietly distinct unit_id
 46.             local units = r(ndistinct)
 47.             quietly distinct ym
 48.             local periods = r(ndistinct)
 49.             quietly distinct unit_id if treat_high == 1
 50.             local high_units = r(ndistinct)
 51.             quietly distinct unit_id if treat_zero == 1
 52.             local zero_units = r(ndistinct)
 53.             quietly distinct unit_id if cno2_identifying == 1
 54.             local cno2_units = r(ndistinct)
 55.             quietly distinct unit_id if cno1_identifying == 1
 56.             local cno1_units = r(ndistinct)
 57.             post COUNTS ("age_cno4") ("`a'") (`rows') (`units') (`periods') (`high_units') (`ze
> ro_units') (`cno2_units') (`cno1_units')
 58.         restore
 59.     }
 60.     postclose COUNTS
 61.     use `counts', clear
 62.     export delimited using "$STTAB\stata_sample_counts.csv", replace
 63. end

