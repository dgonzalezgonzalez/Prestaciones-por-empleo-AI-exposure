. ****** DYNAMIC SDID
. capture program drop run_sdid_event_one

. program define run_sdid_event_one
  1.     syntax, SAMPLE(string) SUBGROUP(string) TAG(string) OUTCOME(name) ESTIMATOR(string)
  2. 
.     preserve
  3.         keep_balanced_panel, outcome(`outcome') restrict("1")
  4.         local nobs = r(nobs)
  5.         local units = r(units)
  6.         local periods = r(periods)
  7.         local treated_units = r(treated_units)
  8.         local control_units = r(control_units)
  9. 
.         if `nobs' == 0 | `treated_units' == 0 | `control_units' == 0 | `periods' < 2 {
 10.             post SDIDEVENT ("`sample'") ("`subgroup'") ("`outcome'") ("`estimator'") ///
>                 (.) (.) (.) (.) (.) (`nobs') (`units') (`periods') (`treated_units') (`control_uni
> ts') ("not_enough_balanced_data") ("")
 11.             restore
 12.             exit
 13.         }
 14. 
.         quietly distinct ym if post_sep2022 == 1
 15.         local effects = r(ndistinct)
 16.         if `effects' > $SDID_EVENT_MAX_EFFECTS {
 17.             local effects = $SDID_EVENT_MAX_EFFECTS
 18.         }
 19.         quietly distinct ym if post_sep2022 == 0
 20.         local placebos = r(ndistinct) - 1
 21.         if `placebos' < 0 {
 22.             local placebos = 0
 23.         }
 24.         if `placebos' > $SDID_EVENT_MAX_PLACEBOS {
 25.             local placebos = $SDID_EVENT_MAX_PLACEBOS
 26.         }
 27. 
.         local event_vce "$SDID_EVENT_VCE"
 28.         if "`event_vce'" == "placebo" & `control_units' <= `treated_units' {
 29.             local event_vce "off"
 30.         }
 31.         set seed $SEED
 32.                 capture noisily sdid_event `outcome' unit_id ym did_post, effects(`effects') pl
> acebo(`placebos') vce(`event_vce') brep($SDID_REPS) method(`estimator')
 33.         *capture noisily sdid_event `outcome' unit_id ym did_post, /*effects(`effects')*/ place
> bo(all) vce(`event_vce') brep($SDID_REPS) method(`estimator')
.         if _rc {
 34.             local rc = _rc
 35.             post SDIDEVENT ("`sample'") ("`subgroup'") ("`outcome'") ("`estimator'") ///
>                 (`effects') (`placebos') (.) (.) (.) (`nobs') (`units') (`periods') (`treated_unit
> s') (`control_units') ("sdid_event_rc_`rc'") ("")
 36.             restore
 37.             exit
 38.         }
 39. 
.         matrix H = e(H)
 40.         tempfile evtable
 41.         clear
 42.         svmat double H
 43.         gen row = _n
 44.         drop if row == 1
 45.         gen int event_time = .
 46.         replace event_time = _n - 1 if _n <= `effects'
 47.         replace event_time = -(_n - `effects') if _n > `effects'
 48.         capture confirm variable H1
 49.         if _rc {
 50.             capture rename h1 H1
 51.             capture rename h2 H2
 52.             capture rename h3 H3
 53.             capture rename h4 H4
 54.             capture rename h5 H5
 55.         }
 56.         rename H1 estimate
 57.         capture rename H2 se
 58.         capture rename H3 ci_low
 59.         capture rename H4 ci_high
 60.         capture rename H5 p_value
 61.         capture confirm variable se
 62.         if _rc gen se = .
 63.         capture confirm variable ci_low
 64.         if _rc gen ci_low = .
 65.         capture confirm variable ci_high
 66.         if _rc gen ci_high = .
 67.         capture confirm variable p_value
 68.         if _rc gen p_value = .
 69.         gen str40 sample = "`sample'"
 70.         gen str80 subgroup = "`subgroup'"
 71.         gen str32 outcome = "`outcome'"
 72.         gen str12 estimator = "`estimator'"
 73.         local event_spec_id "sdid_event_spec1"
 74.         if "`estimator'" == "sc" {
 75.             local event_spec_id "sc_event_spec1"
 76.         }
 77.         gen str32 spec_id = "`event_spec_id'"
 78.         order sample subgroup outcome estimator spec_id event_time estimate se ci_low ci_high p
> _value
 79.         sort event_time
 80.         save `evtable', replace
 81. 
.         local estimator_label = upper("`estimator'")
 82.         if "`estimator'" == "sc" {
 83.             local estimator_label "SC"
 84.         }
 85.         local graphfile "$STFIG\sdid_event_`estimator'_`tag'_`outcome'.png"
 86.         local tablefile "$STTAB\sdid_event_`estimator'_`tag'_`outcome'.csv"
 87.         export delimited using "`tablefile'", replace
 88. 
.         twoway ///
>             (rarea ci_low ci_high event_time if !missing(ci_low, ci_high), color(gs12%45) lcolor(g
> s10)) ///
>             (scatter estimate event_time, mcolor(navy) msymbol(circle) msize(small)) ///
>             (line estimate event_time, lcolor(navy) lwidth(medthin)), ///
>             yline(0, lcolor(gs9)) ///
>             xline(0, lcolor(gs6) lpattern(dash)) ///
>             title("`estimator_label' event study: `sample' `subgroup'") ///
>             subtitle("`event_spec_id'; outcome: `outcome'") ///
>             note("Event 0 is first post month. No CNO1/CNO2 identifying restriction applied.", siz
> e(vsmall)) ///
>             xtitle("Periods relative to first post-treatment month") ///
>             ytitle("Event-study estimate") ///
>             legend(off) ///
>             graphregion(color(white)) plotregion(color(white))
 89.         graph export "`graphfile'", replace width(1600)
 90. 
.         post SDIDEVENT ("`sample'") ("`subgroup'") ("`outcome'") ("`estimator'") ///
>             (`effects') (`placebos') (.) (.) (.) (`nobs') (`units') (`periods') (`treated_units') 
> (`control_units') ("ok") ("`graphfile'")
 91.     restore
 92. end

