 22.             local tag = subinstr("`tag'", "-", "_", .)
 23.             foreach y in ln_parados ln_contratos parados_contratos {
 24.                 foreach m in sdid sc {
 25.                     run_sdid_event_one, sample("age_cno4") subgroup("`a'") tag("age_cno4_`tag'"
> ) outcome(`y') estimator("`m'")
 26.                 }
 27.             }
 28.         restore
 29.     }
 30. 
.     postclose SDIDEVENT
 31.     use `sdidevent', clear
 32.     export delimited using "$STTAB\stata_sdid_event_index.csv", replace
 33.     save "$STDTA\stata_sdid_event_index.dta", replace
 34. end

