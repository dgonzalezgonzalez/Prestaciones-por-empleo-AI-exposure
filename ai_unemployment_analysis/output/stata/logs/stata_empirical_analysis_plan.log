. ******* Check occupation list (4d) of highly exposed occup
. capture program drop make_validation_outputs

. program define make_validation_outputs
  1.     use "$STDTA\panel_total_cno4.dta", clear
  2.     keep cno4 occupation_title exposure_nearest exposure_weighted exposure_rf parados contratos
>  treat_high
  3.     bysort cno4: egen mean_parados = mean(parados)
  4.     bysort cno4: egen mean_contratos = mean(contratos)
  5.     bysort cno4: keep if _n == 1
  6.     gsort -exposure_nearest
  7.     gen exposure_rank = _n
  8.     keep in 1/50
  9.     export delimited using "$STTAB\stata_top50_exposure_occupations.csv", replace
 10. 
.     capture confirm file "$ROOT\output\tables\table_v1_exposure_match_validation_queue.csv"
 11.     if !_rc {
 12.         import delimited using "$ROOT\output\tables\table_v1_exposure_match_validation_queue.cs
> v", clear varnames(1) encoding("UTF-8")
 13.         contract match_review_flag
 14.         rename _freq occupations
 15.         export delimited using "$STTAB\stata_validation_queue_review_counts.csv", replace
 16. 
.         import delimited using "$ROOT\output\tables\table_v1_exposure_match_validation_queue.csv",
>  clear varnames(1) encoding("UTF-8")
 17.         keep if match_review_flag != "ok" | nearest_cosine_similarity < .60
 18.         sort validation_priority_order rank_exposure
 19.         export delimited using "$STTAB\stata_validation_queue_priority_review.csv", replace
 20.     }
 21. end

