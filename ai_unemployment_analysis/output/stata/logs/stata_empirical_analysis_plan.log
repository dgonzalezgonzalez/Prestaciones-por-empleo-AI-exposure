. ******* TWFE DYNAMIC estimates
. 
. capture program drop run_twfe_event_one

. program define run_twfe_event_one
  1.     syntax, SAMPLE(string) SUBGROUP(string) TAG(string) OUTCOME(name) SPECID(string) SPECLABEL(
> string) RESTRICT(string) ABSORB(string)
  2. 
.     preserve
  3.         quietly count if `restrict' & binary_sample == 1 & !missing(`outcome', treat_high, even
> t_time_sep2022, cno4_id)
  4.         local n0 = r(N)
  5.         if `n0' == 0 {
  6.             post TWFEES ("`sample'") ("`subgroup'") ("`outcome'") ("`specid'") ("`speclabel'") 
> ("`restrict'") ("`absorb'") ///
>                 (.) (.) (.) ("no_observations") ("")
  7.             restore
  8.             exit
  9.         }
 10. 
.         levelsof event_time_sep2022 if `restrict' & binary_sample == 1 & !missing(`outcome'), loca
> l(events)
 11.         local terms ""
 12.         foreach e of local events {
 13.             if `e' != -1 {
 14.                 if `e' < 0 {
 15.                     local v "twfe_evt_m`=abs(`e')'"
 16.                 }
 17.                 else {
 18.                     local v "twfe_evt_p`e'"
 19.                 }
 20.                 capture drop `v'
 21.                 gen byte `v' = treat_high == 1 & event_time_sep2022 == `e'
 22.                 local terms "`terms' `v'"
 23.             }
 24.         }
 25. 
.         capture noisily reghdfe `outcome' `terms' if `restrict' & binary_sample == 1, absorb(`abso
> rb') vce(cluster cno4_id)
 26.         if _rc {
 27.             local rc = _rc
 28.             post TWFEES ("`sample'") ("`subgroup'") ("`outcome'") ("`specid'") ("`speclabel'") 
> ("`restrict'") ("`absorb'") ///
>                 (.) (.) (.) ("reghdfe_event_rc_`rc'") ("")
 29.             restore
 30.             exit
 31.         }
 32.         local model_n = e(N)
 33.         local model_r2 = e(r2)
 34.         local model_df = e(df_r)
 35. 
.         tempfile evtable
 36.         postfile EV int event_time double estimate se ci95_low ci95_high p_value using `evtable
> ', replace
 37.         post EV (-1) (0) (.) (.) (.) (.)
 38.         foreach e of local events {
 39.             if `e' != -1 {
 40.                 if `e' < 0 {
 41.                     local v "twfe_evt_m`=abs(`e')'"
 42.                 }
 43.                 else {
 44.                     local v "twfe_evt_p`e'"
 45.                 }
 46.                 capture local beta = _b[`v']
 47.                 if _rc {
 48.                     post EV (`e') (.) (.) (.) (.) (.)
 49.                 }
 50.                 else {
 51.                     local beta = _b[`v']
 52.                     local se = _se[`v']
 53.                     local p = 2 * ttail(e(df_r), abs(`beta' / `se'))
 54.                     local cil = `beta' - invttail(e(df_r), 0.025) * `se'
 55.                     local cih = `beta' + invttail(e(df_r), 0.025) * `se'
 56.                     post EV (`e') (`beta') (`se') (`cil') (`cih') (`p')
 57.                 }
 58.             }
 59.         }
 60.         postclose EV
 61. 
.         local outfile "$STTAB\twfe_event_`tag'_`outcome'_`specid'.csv"
 62.         local graphfile "$STFIG\twfe_event_`tag'_`outcome'_`specid'.png"
 63.         use `evtable', clear
 64.         sort event_time
 65.         export delimited using "`outfile'", replace
 66. 
.         twoway ///
>             (rcap ci95_low ci95_high event_time, lcolor(gs10)) ///
>             (scatter estimate event_time, mcolor(maroon) msymbol(circle) msize(small)) ///
>             (line estimate event_time, lcolor(maroon) lwidth(medthin)), ///
>             yline(0, lcolor(gs9)) ///
>             xline(0, lcolor(gs6) lpattern(dash)) ///
>             title("TWFE event study `specid': `sample' `subgroup'") ///
>             subtitle("Outcome: `outcome'") ///
>             note("`specid' = `speclabel'. Reference month = -1.", size(vsmall)) ///
>             xtitle("Months relative to September 2022") ///
>             ytitle("Log-point or ratio effect") ///
>             legend(off) ///
>             graphregion(color(white)) plotregion(color(white))
 67.         graph export "`graphfile'", replace width(1600)
 68. 
.         post TWFEES ("`sample'") ("`subgroup'") ("`outcome'") ("`specid'") ("`speclabel'") ("`rest
> rict'") ("`absorb'") ///
>             (`model_n') (`model_r2') (`model_df') ("ok") ("`graphfile'")
 69.     restore
 70. end

