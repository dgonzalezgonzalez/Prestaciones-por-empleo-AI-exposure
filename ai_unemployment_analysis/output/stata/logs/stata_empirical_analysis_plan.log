. ******* TWFE STATIC estimates
. capture program drop run_twfe_one

. program define run_twfe_one
  1.     syntax, SAMPLE(string) SUBGROUP(string) OUTCOME(name) SPEC(string) RESTRICT(string) ABSORB(
> string)
  2. 
.     quietly count if `restrict' & binary_sample == 1 & !missing(`outcome', did_post, cno4_id)
  3.     local n0 = r(N)
  4.     if `n0' == 0 {
  5.         post TWFE ("`sample'") ("`subgroup'") ("`outcome'") ("`spec'") ("`restrict'") ("`absorb
> '") ///
>             (.) (.) (.) (.) (.) (.) (.) (.) ("no_observations")
  6.         exit
  7.     }
  8. 
.     capture noisily reghdfe `outcome' did_post if `restrict' & binary_sample == 1, absorb(`absorb'
> ) vce(cluster cno4_id)
  9.     if _rc {
 10.         local rc = _rc
 11.         post TWFE ("`sample'") ("`subgroup'") ("`outcome'") ("`spec'") ("`restrict'") ("`absorb
> '") ///
>             (.) (.) (.) (.) (.) (.) (.) (.) ("reghdfe_rc_`rc'")
 12.         exit
 13.     }
 14. 
.     local beta = _b[did_post]
 15.     local se = _se[did_post]
 16.     local p = 2 * ttail(e(df_r), abs(`beta' / `se'))
 17.     local cil = `beta' - invttail(e(df_r), 0.025) * `se'
 18.     local cih = `beta' + invttail(e(df_r), 0.025) * `se'
 19.     local pct = .
 20.     if inlist("`outcome'", "ln_parados", "ln_contratos") {
 21.         local pct = 100 * (exp(`beta') - 1)
 22.     }
 23.     post TWFE ("`sample'") ("`subgroup'") ("`outcome'") ("`spec'") ("`restrict'") ("`absorb'") 
> ///
>         (`beta') (`se') (`p') (`cil') (`cih') (`pct') (e(N)) (e(r2)) ("ok")
 24. end

