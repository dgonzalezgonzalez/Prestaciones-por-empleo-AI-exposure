. ***** Restrictions for sample
. capture program drop add_restriction_flags

. program define add_restriction_flags
  1.     capture drop cno2_has_high cno2_has_zero cno2_identifying cno1_has_high cno1_has_zero cno1_
> identifying
  2.     bysort cno2: egen cno2_has_high = max(treat_high) if binary_sample == 1
  3.     bysort cno2: egen cno2_has_zero = max(treat_zero) if binary_sample == 1
  4.     gen byte cno2_identifying = cno2_has_high == 1 & cno2_has_zero == 1
  5. 
.     bysort cno1d: egen cno1_has_high = max(treat_high) if binary_sample == 1
  6.     bysort cno1d: egen cno1_has_zero = max(treat_zero) if binary_sample == 1
  7.     gen byte cno1_identifying = cno1_has_high == 1 & cno1_has_zero == 1
  8. end

