. capture program drop run_sdid_event_one

. program define run_sdid_event_one
  1.     syntax, SAMPLE(string) SUBGROUP(string) TAG(string) OUTCOME(name) ESTI
> MATOR(string) VCE(string)
  2. 
.     preserve
  3.         keep_balanced_panel, outcome(`outcome')
  4.         local nobs = r(nobs)
  5.         local units = r(units)
  6.         local periods = r(periods)
  7.         local treated_units = r(treated_units)
  8.         local control_units = r(control_units)
  9. 
.         if `nobs' == 0 | `treated_units' == 0 | `control_units' == 0 | `perio
> ds' < 2 {
 10.             post SDIDEVENT ("`sample'") ("`subgroup'") ("`outcome'") ("`es
> timator'") ("`vce'") ///
>                 (.) (.) (.) (`nobs') (`units') (`periods') (`treated_units') 
> (`control_units') ///
>                 ("not_enough_balanced_data") ("") ("")
 11.             restore
 12.             exit
 13.         }
 14. 
.         quietly distinct ym if post_sep2022 == 1
 15.         local effects = r(ndistinct)
 16.         quietly distinct ym if post_sep2022 == 0
 17.         local placebos = r(ndistinct) - 1
 18.         if `placebos' < 0 {
 19.             local placebos = 0
 20.         }
 21. 
.         display as text "Running sdid_event: sample=`sample' subgroup=`subgro
> up' outcome=`outcome' estimator=`estimator'"
 22.         display as text "  nobs=`nobs' units=`units' periods=`periods' tre
> ated=`treated_units' controls=`control_units' effects=`effects' placebos=`pla
> cebos'"
 23. 
.         local vceopt "vce(off)"
 24.         if "`vce'" == "placebo" {
 25.             local vceopt "vce(placebo) brep($SDID_EVENT_REPS)"
 26.         }
 27.         capture noisily sdid_event `outcome' unit_id ym did_post, effects(
> `effects') placebo(`placebos') `vceopt' method(`estimator')
 28.         if _rc {
 29.             local rc = _rc
 30.             display as error "sdid_event failed with rc=`rc'"
 31.             post SDIDEVENT ("`sample'") ("`subgroup'") ("`outcome'") ("`es
> timator'") ("`vce'") ///
>                 (`effects') (`placebos') (.) (`nobs') (`units') (`periods') (
> `treated_units') (`control_units') ///
>                 ("sdid_event_rc_`rc'") ("") ("")
 32.             restore
 33.             exit
 34.         }
 35. 
.         matrix H_att = e(H)
 36.         local att = H_att[1,1]
 37.         export_event_results, sample("`sample'") subgroup("`subgroup'") ta
> g("`tag'") outcome(`outcome') estimator("`estimator'") effects(`effects') pla
> cebos(`placebos') vce("`vce'")
 38.         post SDIDEVENT ("`sample'") ("`subgroup'") ("`outcome'") ("`estima
> tor'") ("`vce'") ///
>             (`effects') (`placebos') (`att') (`nobs') (`units') (`periods') (
> `treated_units') (`control_units') ///
>             ("ok") ("`tablefile'") ("`graphfile'")
 39.     restore
 40. end

