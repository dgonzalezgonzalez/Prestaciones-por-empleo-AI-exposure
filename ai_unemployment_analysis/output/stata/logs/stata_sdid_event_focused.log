. capture program drop keep_balanced_panel

. program define keep_balanced_panel, rclass
  1.     syntax, OUTCOME(name)
  2. 
.     keep if binary_sample == 1
  3.     keep if !missing(`outcome', did_post, unit_id, ym)
  4.     duplicates drop unit_id ym, force
  5. 
.     quietly levelsof ym, local(allmonths)
  6.     local T : word count `allmonths'
  7.     bysort unit_id: egen n_months_unit = count(ym)
  8.     keep if n_months_unit == `T'
  9. 
.     bysort unit_id: egen ever_treated = max(treat_high)
 10.     bysort unit_id: egen ever_zero = max(treat_zero)
 11.     keep if ever_treated == 1 | ever_zero == 1
 12. 
.     quietly distinct unit_id if ever_treated == 1
 13.     return scalar treated_units = r(ndistinct)
 14.     quietly distinct unit_id if ever_zero == 1
 15.     return scalar control_units = r(ndistinct)
 16.     quietly distinct unit_id
 17.     return scalar units = r(ndistinct)
 18.     quietly distinct ym
 19.     return scalar periods = r(ndistinct)
 20.     quietly count
 21.     return scalar nobs = r(N)
 22. end

