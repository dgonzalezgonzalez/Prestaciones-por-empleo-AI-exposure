. capture program drop make_gender_panel

. program define make_gender_panel
  1.     use "$STDTA/stata_master_clean.dta", clear
  2.     keep if lower(dimension) == "gender"
  3.     gen gender_group = category
  4.     egen unit_id = group(cno4)
  5.     save "$STDTA/panel_gender_cno4_for_sdid_event.dta", replace
  6. end

. 
. capture program drop make_age3_panel

. program define make_age3_panel
  1.     use "$STDTA/panel_age_cno4.dta", clear
  2.     gen str20 age3_group = ""
  3.     replace age3_group = "<18 to 29" if inlist(age_group, "<18", "18-24", 
> "25-29")
  4.     replace age3_group = "30-39" if age_group == "30-39"
  5.     replace age3_group = "40 to >44" if inlist(age_group, "40-44", ">44")
  6.     keep if age3_group != ""
  7. 
.     collapse (sum) parados contratos ///
>         (firstnm) exposure_nearest exposure_weighted exposure_rf treat_high t
> reat_zero binary_sample post_sep2022 did_post cno2 cno1d event_time_sep2022, 
> ///
>         by(age3_group cno4 ym period occupation_title)
  8. 
.     gen ln_parados = ln(parados) if parados > 0
  9.     gen ln_contratos = ln(contratos) if contratos > 0
 10.     gen parados_contratos = parados / contratos if contratos > 0 & parados
>  < .
 11.     capture drop cno4_id cno2_id cno1_id unit_id
 12.     egen cno4_id = group(cno4)
 13.     egen cno2_id = group(cno2)
 14.     egen cno1_id = group(cno1d)
 15.     egen unit_id = group(cno4)
 16.     save "$STDTA/panel_age3_cno4_for_sdid_event.dta", replace
 17. end

